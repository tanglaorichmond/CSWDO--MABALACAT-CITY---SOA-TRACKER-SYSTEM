rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      return getUserData().role;
    }

    function canUserEdit() {
      return getUserData().get('canEdit', false) == true;
    }

    function canUserDelete() {
      return getUserData().get('canDelete', false) == true;
    }

    // Default deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Match test_connection
    match /test_connection/{docId} {
      allow read, write: if true;
    }

    // Match users collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || (userExists() && getUserData().role == "System Administrator"));
      allow list: if isSignedIn() && userExists() && getUserData().role == "System Administrator";
      allow create, update: if isSignedIn() && (
        request.auth.uid == userId || (
          userExists() && getUserData().role == "System Administrator"
        )
      );
      allow delete: if isSignedIn() && 
                    userExists() && 
                    getUserData().role == "System Administrator";
    }

    // Match soas collection
    match /soas/{soaId} {
      allow read: if true;
      allow create, update: if isSignedIn() && (
        !userExists() || 
        getUserData().role == "System Administrator" || 
        getUserData().role == "Admin" || (
          getUserData().role == "User" && 
          getUserData().get('canEdit', true) == true
        )
      );
      allow delete: if isSignedIn() && userExists() && (
        getUserData().role == "System Administrator" || 
        getUserData().role == "Admin" || (
          getUserData().role == "User" && 
          getUserData().get('canDelete', false) == true
        )
      );
    }
    
    // Match registrationRequests collection
    match /registrationRequests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn() && 
                                    userExists() && 
                                    getUserData().role == "System Administrator";
    }
    
    // Match stakeholders collection
    match /stakeholders/{stakeholderId} {
      allow read: if true;
      allow create, update: if isSignedIn() && (
        !userExists() || 
        getUserData().role == "System Administrator" || 
        getUserData().role == "Admin" || (
          getUserData().role == "User" && 
          getUserData().get('canEdit', true) == true
        )
      );
      allow delete: if isSignedIn() && userExists() && (
        getUserData().role == "System Administrator" || 
        getUserData().role == "Admin" || (
          getUserData().role == "User" && 
          getUserData().get('canDelete', false) == true
        )
      );
    }
    
    // Match settings collection
    match /settings/{settingsId} {
      allow read: if isSignedIn() && userExists() && getUserData().role != "Admin";
      allow write: if isSignedIn() && userExists() && getUserData().role == "System Administrator";
    }
  }
}
